{
  "files.eol": "\r\n",
  "files.encoding": "utf8",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "[lua]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[xml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[json]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "stylua.configPath": "./stylua.toml",
  "Lua.misc.parameters": ["--locale=en-us"],
  "cSpell.enabled": true,
  "Lua.runtime.version": "Lua 5.1",
  "Lua.runtime.builtin": {
    "basic": "disable",
    "debug": "disable",
    "io": "disable",
    "math": "disable",
    "os": "disable",
    "package": "disable",
    "string": "disable",
    "table": "disable",
    "utf8": "disable"
  },
  "Lua.workspace.library": [
    "/Users/steven/.antigravity/extensions/ketho.wow-api-0.22.3/Annotations/Core"
  ],
  "Lua.diagnostics.disable": [
    "ambiguity-1",
    "cast-local-type",
    "deprecated",
    "duplicate-set-field",
    "inject-field",
    "lowercase-global",
    "missing-fields",
    "missing-parameter",
    "missing-return",
    "need-check-nil",
    "param-type-mismatch",
    "redundant-parameter",
    "unbalanced-assignments",
    "undefined-field",
    "undefined-global"
  ],
  "wowAPI.luals.frameXML": false
}
